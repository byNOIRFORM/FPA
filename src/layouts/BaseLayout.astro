---
import "../styles/tokens.css";
import "../styles/global.css";
import "lenis/dist/lenis.css";
import Loader from "../components/Loader.astro";
import ContactForm from "../components/ContactForm.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Atelier",
  description = "Architektonický ateliér",
} = Astro.props;
---

<!doctype html>
<html lang="sk">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    {/* Favicon — SVG house from the loader. Embedded
        prefers-color-scheme rule inverts the stroke on dark browser
        themes. Modern browsers (95%+ traffic) support SVG favicons;
        no ICO fallback ships intentionally — old Astro default ICO
        was deleted to prevent cached-favicon confusion. The ?v=2
        query busts any stale browser cache from the previous icon. */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=5" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin />

    {/* Switzer = project default sans (Fontshare). Loads regular,
        regular italic, medium, medium italic, semibold, bold.
        (Fontshare convention: .1 suffix on weight = italic variant —
         401 = Regular Italic, 501 = Medium Italic.) */}
    <link
      rel="stylesheet"
      href="https://api.fontshare.com/v2/css?f[]=switzer@400,401,500,501,600,700&display=swap"
    />

    {/* Display serif + mono kept for headings and labels. */}
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    {/* Preload hero — image must be decoded by the time the loader
        curtain rises so the Ken Burns scale-settle plays smoothly
        without bitmap decoding hitching on first paint. */}
    <link rel="preload" as="image" href="/images/hero.jpg" />
  </head>
  <body data-loader-active>
    <Loader />

    {/* Custom cursor — circle ring + small square in the centre.
        Hidden on touch / small screens via CSS in global.css. */}
    <div class="cursor" id="cursor" aria-hidden="true">
      <span class="cursor-square"></span>
      <span class="cursor-ring"></span>
    </div>

    <slot />

    {/* Contact form lives at the layout level so any CTA on any
        page can open it via [data-open-contact]. */}
    <ContactForm />

    <script>
      import { setupGsap } from "../scripts/gsap-setup";
      import { initLoader } from "../scripts/loader";
      import { initHero } from "../scripts/hero";
      import { initAbout } from "../scripts/about";
      import { initWorks } from "../scripts/works";
      import { initServices } from "../scripts/services";
      import { initNav } from "../scripts/nav";
      import { initContactForm } from "../scripts/contact-form";
      setupGsap();
      initHero();
      initAbout();
      initWorks();
      initServices();
      initNav();
      initContactForm();
      initLoader();
    </script>
  </body>
</html>
