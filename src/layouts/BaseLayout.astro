---
import "../styles/tokens.css";
import "../styles/global.css";
import "lenis/dist/lenis.css";
import Loader from "../components/Loader.astro";
import ContactForm from "../components/ContactForm.astro";
import SideNav from "../components/SideNav.astro";
import PageTransition from "../components/PageTransition.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import GridOverlay from "../components/GridOverlay.astro";
import Nav from "../components/Nav.astro";
import { home, type Lang } from "../i18n/home";

interface Props {
  title?: string;
  description?: string;
  /** Show the intro house-loader. True on the landing; subpages
   *  (e.g. /sluzby) pass false so they don't replay the full intro
   *  on every navigation. */
  loader?: boolean;
  /** Document language for <html lang> — SK / CZ / EN landing pages. */
  lang?: Lang;
  /** Shared nav variant — "home" (landing) or "sub" (subpages). */
  navVariant?: "home" | "sub";
  /** Marks the current-page primary nav link on subpages. */
  navActive?: "about" | "projects" | "services";
}

const {
  title = "Atelier",
  description = "Architektonický ateliér",
  loader = true,
  lang = "sk",
  navVariant = "home",
  navActive,
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    {/* viewport-fit=cover lets full-bleed sections (hero, intro) extend
        under the notch / home indicator instead of leaving a cream safe-area
        band; the nav + side-nav already pad with env(safe-area-inset-*). */}
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    {/* THEME — resolve light/dark BEFORE first paint to avoid a flash.
        Order of truth: explicit stored choice → OS preference → light.
        Sets data-theme on <html> synchronously; theme-toggle.ts keeps
        it in sync afterwards. */}
    <script is:inline>
      try {
        var stored = localStorage.getItem("fpa:theme");
        var theme =
          stored ||
          (window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light");
        document.documentElement.setAttribute("data-theme", theme);
      } catch (e) {}
    </script>

    {/* Page-transition arrival flag — must run synchronously BEFORE
        first paint so the new document is dark from its very first
        frame. The cover is applied via INLINE styles + an injected
        <style> element (NOT the bundled stylesheet): the dev server
        loads CSS through JS after first paint, which is what caused
        the white flash between pages. page-transition.ts cleans all
        of this up once its curtain holds the screen. */}
    <script is:inline>
      try {
        if (sessionStorage.getItem("fpa:pt")) {
          sessionStorage.removeItem("fpa:pt");
          var d = document.documentElement;
          d.setAttribute("data-pt", "");
          d.style.background = "#222";
          var s = document.createElement("style");
          s.id = "pt-boot";
          s.textContent = "body{visibility:hidden}";
          document.head.appendChild(s);
        }
      } catch (e) {}
    </script>

    {/* Favicon — SVG house from the loader. Embedded
        prefers-color-scheme rule inverts the stroke on dark browser
        themes. Modern browsers (95%+ traffic) support SVG favicons;
        no ICO fallback ships intentionally — old Astro default ICO
        was deleted to prevent cached-favicon confusion. The ?v=2
        query busts any stale browser cache from the previous icon. */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=5" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin />

    {/* Switzer = project default sans (Fontshare). Loads regular,
        regular italic, medium, medium italic, semibold, bold.
        (Fontshare convention: .1 suffix on weight = italic variant —
         401 = Regular Italic, 501 = Medium Italic.) */}
    <link
      rel="stylesheet"
      href="https://api.fontshare.com/v2/css?f[]=switzer@400,401,500,501,600,700&display=swap"
    />

    {/* Display serif + mono kept for headings and labels. */}
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    {/* Preload hero — image must be decoded by the time the loader
        curtain rises so the Ken Burns scale-settle plays smoothly
        without bitmap decoding hitching on first paint. */}
    <link rel="preload" as="image" href="/images/hero.jpg" />
  </head>
  <body data-loader-active={loader ? "" : undefined}>
    {loader && <Loader />}

    {/* Shared site nav — rendered at the page ROOT so it is never trapped
        inside a section's stacking context (e.g. the sticky intro on
        /sluzby, where a nested nav rendered under later sections). One
        nav for the whole site. */}
    <Nav lang={lang} variant={navVariant} active={navActive} />

    {/* Custom cursor — circle ring + small square in the centre.
        Hidden on touch / small screens via CSS in global.css. */}
    <div class="cursor" id="cursor" aria-hidden="true">
      <span class="cursor-square"></span>
      <span class="cursor-ring" data-view-label={home[lang].cursorView}></span>
    </div>

    <slot />

    {/* Contact form lives at the layout level so any CTA on any
        page can open it via [data-open-contact]. */}
    <ContactForm lang={lang} />

    {/* Mobile side navigation (≤767px) — opened by the nav "Menu"
        button via [data-open-menu]. Hidden on tablet/desktop. */}
    <SideNav lang={lang} />

    {/* Page-transition curtain — sweeps over the page on internal
        navigation; see scripts/page-transition.ts. */}
    <PageTransition />

    {/* Light/dark switch — fixed bottom-right, on every page. */}
    <ThemeToggle lang={lang} />

    {/* Structure easter egg — press-and-hold the logo to reveal the
        12-column grid (see GridOverlay + scripts/grid-reveal.ts). */}
    <GridOverlay />

    <script>
      import { setupGsap } from "../scripts/gsap-setup";
      import { initThemeToggle } from "../scripts/theme-toggle";
      import { initGridReveal } from "../scripts/grid-reveal";
      import { initLoader } from "../scripts/loader";
      import { initHero } from "../scripts/hero";
      import { initAbout } from "../scripts/about";
      import { initWorks } from "../scripts/works";
      import { initServices } from "../scripts/services";
      import { initLeaders } from "../scripts/leaders";
      import { initFooter } from "../scripts/footer";
      import { initNav } from "../scripts/nav";
      import { initContactForm } from "../scripts/contact-form";
      import { initSideNav } from "../scripts/side-nav";
      import { initPageTransition } from "../scripts/page-transition";
      setupGsap();
      initHero();
      initAbout();
      initWorks();
      initServices();
      initLeaders();
      initFooter();
      initNav();
      initContactForm();
      initSideNav();
      initPageTransition();
      initThemeToggle();
      initGridReveal();
      initLoader();
    </script>
  </body>
</html>
