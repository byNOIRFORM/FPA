---
import BaseLayout from "../layouts/BaseLayout.astro";
import ServicesIntro from "../components/ServicesIntro.astro";
import ServicesScope from "../components/ServicesScope.astro";
import BuildingTypes from "../components/BuildingTypes.astro";
import ServicesManifest from "../components/ServicesManifest.astro";
import ServicesStages from "../components/ServicesStages.astro";
import Services from "../components/Services.astro";
import Footer from "../components/Footer.astro";
---

{/* Subpage — no intro loader (it only plays on the landing). */}
<BaseLayout
  title="Služby — Fotta // Popadič"
  description="Od precízneho výkresu po trvácnu architektúru — kompletná projektová dokumentácia ateliéru Fotta // Popadič."
  loader={false}
  navVariant="sub"
  navActive="services"
>
  <ServicesIntro />
  <ServicesScope />
  <BuildingTypes />
  <ServicesManifest />
  <ServicesStages />
  {/* Detailed spec-sheet — reuses the homepage Services section + effects. */}
  <Services lang="sk" detailed />
  {/* Same footer as the homepage. */}
  <Footer lang="sk" />
</BaseLayout>
