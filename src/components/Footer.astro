---
/**
 * Footer (Section 6) — closing chord of the landing page.
 *
 * Figma spec (node 2926:2116):
 *   - Top row: brand lockup (FOTTA//POPADIČ + architekt) on the
 *     left, "Kontaktujte nás" CTA on the right.
 *   - Pitch paragraph: Switzer Regular 32px, ~915px wide.
 *     "Ak hľadáte partnera, ktorý spojí mladistvú energiu…"
 *   - 4-column info grid (centered on 1384):
 *       · Kde nás najdete  (Bardejov + Košice addresses)
 *       · Informácie       (s.r.o. + IČO + DIČ)
 *       · Navigácia        (5 site links)
 *       · Sociálne siete   (Facebook + Linkedin)
 *   - Bottom row: All rights reserved · Späť na vrch · Made by NOIRFØRM
 *     (3 evenly spread items at the bottom of the page).
 *
 * Motion is intentionally minimal — footer is functional, not a
 * stage for choreography. Just standard hover states on links and
 * the lenis-powered scroll-to-top behaviour wired in footer.ts,
 * plus a per-word fade-up reveal on the pitch paragraph.
 */

// Pitch broken into per-word spans so each word can fade up
// independently with a small stagger (same word-split technique
// as the About / Leaders manifest scrubs). Layout-safe at any
// resolution: each span is inline-block and wraps as a natural
// word boundary, so line breaks follow the container width
// exactly as they would for plain text.
const PITCH_LINE_1 =
  "Ak hľadáte partnera, ktorý spojí mladistvú energiu s bohatými skúsenosťami a vášňou k architektúre, ste na správnom mieste.";
const PITCH_LINE_2 =
  "Pre cenovú ponuku nás kontaktujte telefonicky alebo emailom.";
const pitchLine1 = PITCH_LINE_1.split(" ");
const pitchLine2 = PITCH_LINE_2.split(" ");
---

<footer class="footer" aria-labelledby="footer-heading">
  <h2 class="visually-hidden" id="footer-heading">Pätička</h2>

  {/* TOP — brand lockup alone on the left (matches Figma where
      the logo sits at top-7556 with the CTA much lower at 7828). */}
  <a class="footer-logo" href="/" aria-label="Fotta // Popadič — architekt — domov">
    <span class="footer-logo-main">FOTTA//POPADIČ</span>
    <span class="footer-logo-sub">architekt</span>
  </a>

  {/* PITCH — large editorial paragraph that opens the footer.
      MASK REVEAL pattern from Hero — each word sits inside an
      overflow:hidden mask so when footer.ts translates the
      word from yPercent:110 to 0 it visibly "rises" from below
      the line. Same parameters as the hero slogan reveal
      (duration 1.0, expo.out, stagger 0.05).
      Layout-safe at any resolution: mask spans are inline-block
      and wrap as natural word boundaries — text flow is
      identical to plain text. */}
  <p class="footer-pitch" data-reveal>
    {pitchLine1.map((w, i) => (
      <>
        <span class="footer-pitch-mask"
          ><span class="footer-pitch-word">{w}</span></span
        >
        {i < pitchLine1.length - 1 ? " " : ""}
      </>
    ))}
    <br />
    {pitchLine2.map((w, i) => (
      <>
        <span class="footer-pitch-mask"
          ><span class="footer-pitch-word">{w}</span></span
        >
        {i < pitchLine2.length - 1 ? " " : ""}
      </>
    ))}
  </p>

  {/* CTA — CENTERED below the pitch (same alignment convention as
      About / Works / Services / Leaders CTAs). Identical button
      spec to all other primary CTAs (211×44, font-weight 500,
      curtain hover + text/arrow shift). */}
  <a class="footer-cta" href="#kontakt" data-open-contact>
    <span class="footer-cta-text">Kontaktujte nás</span>
    <svg
      class="footer-cta-arrow"
      width="16"
      height="10"
      viewBox="0 0 16 10"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M0 5 H14 M10 1 L14 5 L10 9" />
    </svg>
  </a>

  {/* 4-COLUMN INFO GRID */}
  <div class="footer-grid">
    {/* Col 1 — Locations */}
    <section class="footer-col">
      <h3 class="footer-col-label">Kde nás najdete</h3>
      <div class="footer-locations">
        <address class="footer-location">
          <p class="footer-location-name">Bardejov</p>
          <p>Priemyselná 3767, 085 01 Bardejov, Slovensko</p>
          <p>Telefón: <a href="tel:+421907183302">+421 907 183 302</a></p>
          <p>Email: <a href="mailto:atelier@fottapopadic.sk">atelier@fottapopadic.sk</a></p>
        </address>
        <address class="footer-location">
          <p class="footer-location-name">Košice</p>
          <p>Dominikánske námestie 590/6, 040 01 Staré Mesto, Slovensko</p>
        </address>
      </div>
    </section>

    {/* Col 2 — Company info */}
    <section class="footer-col">
      <h3 class="footer-col-label">Informácie</h3>
      <p class="footer-company">
        Fotta Popadič Architekt s.r.o.<br />
        IČO: 53802012<br />
        DIČ: 2121502680
      </p>
    </section>

    {/* Cols 3+4 — Navigation + Social paired in a tighter sub-grid
        (matches Figma: the two link columns sit closer together as
        one group, separated by the wider 142px gap from the
        address/info columns). */}
    <div class="footer-nav-pair">
      <section class="footer-col">
        <h3 class="footer-col-label">Navigácia</h3>
        <ul class="footer-links">
          <li><a href="/" class="nav-flip" data-text="Domov"><span>Domov</span></a></li>
          <li><a href="#o-nas" class="nav-flip" data-text="O nás"><span>O nás</span></a></li>
          <li><a href="#projekty" class="nav-flip" data-text="Projekty"><span>Projekty</span></a></li>
          <li><a href="#sluzby" class="nav-flip" data-text="Služby"><span>Služby</span></a></li>
          <li><a href="#kariera" class="nav-flip" data-text="Kariéra"><span>Kariéra</span></a></li>
        </ul>
      </section>

      <section class="footer-col">
        <h3 class="footer-col-label">Sociálne siete</h3>
        <ul class="footer-links">
          <li>
            <a class="nav-flip" data-text="Facebook" href="https://www.facebook.com/" target="_blank" rel="noopener noreferrer">
              <span>Facebook</span>
            </a>
          </li>
          <li>
            <a class="nav-flip" data-text="Linkedin" href="https://www.linkedin.com/" target="_blank" rel="noopener noreferrer">
              <span>Linkedin</span>
            </a>
          </li>
        </ul>
      </section>
    </div>
  </div>

  {/* BOTTOM ROW — copyright · back to top · credit.
      "Späť na vrch" uses the same .nav-flip text-flip hover as
      the Navigation column above and the Hero nav links. */}
  <div class="footer-bottom">
    <span class="footer-copyright">All rights reserved</span>
    <button class="footer-totop nav-flip" type="button" data-back-to-top data-text="Späť na vrch">
      <span>Späť na vrch</span>
    </button>
    <a class="footer-credit" href="https://noirform.com" target="_blank" rel="noopener noreferrer">
      Made by NOIRFØRM
    </a>
  </div>
</footer>

<style>
  /* ===== Visually-hidden — accessibility heading not visible
     to sighted users but read by screen readers. */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ===== Section frame =====
     Same outer padding / max-width as other sections so the
     footer aligns to the same canvas. */
  .footer {
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 2464px;
    margin: 0 auto;
    /* Top padding identical to About + Works + Leaders (clamp
       80→180 at 8.33vw = 120 at 1440). Horizontal gutter matches
       all other sections. Bottom keeps a small breathing zone
       before the page ends. */
    padding: clamp(80px, 8.33vw, 180px) clamp(16px, 2vw, 48px) clamp(20px, 1.94vw, 36px);
    background: var(--bg);
    color: var(--ink);
  }

  /* ============================================================
     LOGO — top-left, alone (matches Figma where logo is at the
     very top of the footer and the CTA is much further down).
     Left-aligned to the inner section edge (no max-width
     centering) so it lines up with everything else.
     ============================================================ */
  .footer-logo {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--ink);
    line-height: 1;
    letter-spacing: 0.02em;
    margin: 0;
  }

  .footer-logo-main {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(18px, 1.67vw, 26px);
    line-height: 1.08;
  }

  .footer-logo-sub {
    font-family: var(--font-sans);
    font-weight: 400;
    font-style: italic;
    font-size: clamp(18px, 1.67vw, 26px);
    line-height: 1.08;
    color: var(--ink);
  }

  /* ===== CTA — CENTERED below the pitch, 48px above (matches
     Services / Leaders CTA spacing exactly). Same 211×44 button
     spec + curtain hover as every other primary CTA. */
  .footer-cta {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(10px, 0.83vw, 12px);
    width: clamp(180px, 14.65vw, 211px);
    margin-top: clamp(24px, 3.33vw, 48px);
    padding: clamp(10px, 0.97vw, 14px) clamp(12px, 1.11vw, 16px);
    background: #222;
    color: #fff;
    text-decoration: none;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(14px, 1.11vw, 16px);
    line-height: 1;
    letter-spacing: 0.02em;
    overflow: hidden;
    align-self: center;
    will-change: transform;
  }

  .footer-cta::before {
    content: "";
    position: absolute;
    inset: 0;
    background: #000;
    transform: translateX(-101%);
    transition: transform 520ms cubic-bezier(0.65, 0, 0.35, 1);
    will-change: transform;
    z-index: 0;
  }

  .footer-cta:hover::before {
    transform: translateX(0);
  }

  .footer-cta > * {
    position: relative;
    z-index: 1;
  }

  .footer-cta-text {
    display: inline-block;
    transition: transform 420ms cubic-bezier(0.65, 0, 0.35, 1);
    will-change: transform;
  }

  .footer-cta:hover .footer-cta-text {
    transform: translateX(3px);
  }

  .footer-cta-arrow {
    display: block;
    flex: 0 0 auto;
    transition: transform 440ms cubic-bezier(0.65, 0, 0.35, 1);
    will-change: transform;
  }

  .footer-cta:hover .footer-cta-arrow {
    transform: translateX(7px);
  }

  /* ============================================================
     PITCH — large editorial paragraph, exactly 3 lines:
       L1 + L2: sentence 1 (auto-wrapped, balanced via text-wrap)
       L3:      sentence 2 (forced onto its own line via <br/>)
     Font capped at 32px (Figma baseline) so the wrap stays
     consistent at viewports above 1440. Width bumped to 1024
     so sentence 1 fits in 2 balanced lines (~62 chars each)
     instead of leaving "mieste." orphaned on its own line.
     text-wrap: pretty tells the browser to use a slower
     algorithm that specifically avoids short orphan words at
     paragraph end — modern Chromium / WebKit / Firefox honour
     it; older browsers fall back to default wrapping (3 lines
     still happen thanks to the width + font cap).
     ============================================================ */
  .footer-pitch {
    font-family: var(--font-sans);
    font-weight: 400;
    font-style: normal;
    font-size: clamp(22px, 2.22vw, 32px);
    line-height: 1.25;
    letter-spacing: 0.01em;
    color: var(--ink);
    max-width: 1024px;
    width: 100%;
    /* Left-aligned to the inner section edge — no margin-left
       trickery. Lines up with the logo above and the rest of
       the page's left content edge. */
    margin: clamp(40px, 4.44vw, 96px) 0 0;
    text-wrap: pretty;
  }

  /* ===== Mask-reveal pattern (mirrors Hero slogan) =====
     Each word sits inside .footer-pitch-mask (overflow:hidden)
     and footer.ts translates the inner word from yPercent:110
     to 0 — the word visibly RISES from below the line.

     vertical-align:bottom keeps the masks baseline-aligned with
     surrounding text (default baseline alignment of an inline-
     block with overflow:hidden sits at the bottom of the box,
     which can nudge lines; bottom alignment matches the line's
     bottom edge consistently). */
  .footer-pitch-mask {
    display: inline-block;
    overflow: hidden;
    line-height: inherit;
    vertical-align: bottom;
  }

  /* IMPORTANT: no CSS transform here (same reasoning as
     .hero-title-word — GSAP reads CSS translateY(%) as a pixel
     value via matrix decomposition and stashes it in `y`, so a
     subsequent yPercent tween would leave the pixel offset
     uncleared and the word would never reach yPercent:0).
     opacity:0 alone hides it until footer.ts seeds yPercent
     and runs the reveal. */
  .footer-pitch-word {
    display: inline-block;
    opacity: 0;
    will-change: transform, opacity;
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-pitch-word {
      opacity: 1;
    }
  }

  /* ============================================================
     INFO GRID — 3 column GROUPS, not 4 equal columns.
     Layout proportions taken from Figma:
       · Kde nás najdete : 327/1384 = 23.6%
       · Informácie       : 327/1384 = 23.6%
       · Nav + Social pair: 446/1384 = 32.2% (211 + 25 + 210)
       · Main gap         : 142/1384 = 10.3%
     Inside the pair, Navigation + Sociálne siete share a much
     tighter sub-gap (25px @1440 = 5.6% of the pair's width)
     so they read as ONE column group, not two separate columns
     adrift from the rest.
     ============================================================ */
  .footer-grid {
    display: flex;
    flex-wrap: nowrap;
    width: 100%;
    gap: calc(142 / 1384 * 100%);
    margin: clamp(48px, 5.55vw, 120px) 0 0;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: clamp(14px, 1.39vw, 24px);
    min-width: 0;
  }

  /* First 2 column groups (Kde nás, Informácie) — each 327/1384
     of the grid width. */
  .footer-grid > .footer-col {
    flex: 0 0 calc(327 / 1384 * 100%);
  }

  /* 3rd group — Nav + Social paired together with their own
     tighter sub-gap. Pair width 446/1384; internal gap 25/446. */
  .footer-nav-pair {
    flex: 0 0 calc(446 / 1384 * 100%);
    display: flex;
    flex-wrap: nowrap;
    gap: calc(25 / 446 * 100%);
    min-width: 0;
  }

  .footer-nav-pair > .footer-col {
    flex: 1 1 0;
    min-width: 0;
  }

  /* Column label — small grey hint above each block */
  .footer-col-label {
    font-family: var(--font-sans);
    font-weight: 400;
    font-style: normal;
    font-size: clamp(13px, 1.11vw, 18px);
    line-height: 1.2;
    letter-spacing: 0.02em;
    color: var(--ink-mute);
    margin: 0;
  }

  /* ===== Locations =====
     Stack of two address blocks (Bardejov + Košice), separated
     by a small gap so they read as distinct locations not one
     long block. */
  .footer-locations {
    display: flex;
    flex-direction: column;
    gap: clamp(20px, 2.22vw, 40px);
  }

  .footer-location {
    font-style: normal;
    font-family: var(--font-sans);
    font-weight: 400;
    /* 20 at 1440 → matches .footer-links and the Figma spec for
       address text (Switzer Regular 20px). */
    font-size: clamp(16px, 1.39vw, 20px);
    line-height: 1.5;
    color: var(--ink);
  }

  .footer-location p {
    margin: 0;
  }

  .footer-location-name {
    /* Same weight as work-title so location name reads as a
       small heading within the block. */
    font-weight: 500;
    font-size: clamp(16px, 1.39vw, 20px);
    line-height: 1.3;
    color: var(--ink);
    margin-bottom: clamp(4px, 0.42vw, 8px) !important;
  }

  .footer-location a {
    color: var(--ink);
    text-decoration: none;
    transition: color 280ms cubic-bezier(0.65, 0, 0.35, 1);
  }

  .footer-location a:hover {
    color: var(--ink-mute);
  }

  /* ===== Company info ===== */
  .footer-company {
    font-family: var(--font-sans);
    font-weight: 400;
    /* Match address + nav-link size — 20 at 1440. */
    font-size: clamp(16px, 1.39vw, 20px);
    line-height: 1.5;
    color: var(--ink);
    margin: 0;
  }

  /* ===== Link lists (nav + social) =====
     gap is 0 — vertical spacing between items is owned entirely
     by the nav-flip's line-height (1.4 = 28px at 20 font). The
     earlier gap of 6px stacked on top of a 30px line-height
     made the list read as too airy compared to the Figma. */
  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* ===== Generic .nav-flip — base flip behavior reused by every
     hover-flippable element in the footer (nav links, social
     links, and the "Späť na vrch" button). Container is
     overflow:hidden so the duplicate-text from the ::after
     data-text doesn't leak outside the element. Animation
     duration / easing matches Hero's .nav-flip exactly. */
  .nav-flip {
    position: relative;
    display: inline-block;
    overflow: hidden;
    vertical-align: middle;
  }

  .nav-flip span {
    display: inline-block;
    transition: transform 360ms cubic-bezier(0.65, 0, 0.35, 1);
    will-change: transform;
  }

  .nav-flip::after {
    content: attr(data-text);
    position: absolute;
    inset: 0;
    display: inline-block;
    transform: translateY(100%);
    transition: transform 360ms cubic-bezier(0.65, 0, 0.35, 1);
    will-change: transform;
  }

  .nav-flip:hover span,
  .nav-flip:focus-visible span {
    transform: translateY(-100%);
  }

  .nav-flip:hover::after,
  .nav-flip:focus-visible::after {
    transform: translateY(0);
  }

  /* Link-specific font for the nav + social columns.
     line-height 1.4 matches Figma's `leading-normal` on the
     <p> items — tighter than the previous 1.5 so the list
     stacks compactly. */
  .footer-links .nav-flip {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(16px, 1.39vw, 20px);
    line-height: 1.4;
    letter-spacing: 0.02em;
    color: var(--ink);
    text-decoration: none;
  }

  /* ============================================================
     BOTTOM ROW — copyright | back to top | credit
     Sits 120px below the info grid (matches Figma) and shares
     the 20px size with the rest of the footer text.
     ============================================================ */
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(16px, 2vw, 32px);
    width: 100%;
    /* Spans the full inner section width — copyright at the
       inner-left edge, credit at the inner-right edge,
       Späť na vrch centered. Matches the Figma 3-spread layout.
       120 at 1440 above (8.33vw) — explicit gap to info grid. */
    margin: clamp(56px, 8.33vw, 140px) 0 0;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(14px, 1.39vw, 20px);
    line-height: 1.4;
    letter-spacing: 0.02em;
    color: var(--ink);
  }

  .footer-copyright {
    /* Stays left */
  }

  /* Button reset — font + color inherit from .footer-bottom so
     the size automatically matches. The .nav-flip class on this
     button provides the text-flip hover. */
  .footer-totop {
    appearance: none;
    background: none;
    border: 0;
    padding: 0;
    margin: 0;
    cursor: pointer;
    font: inherit;
    color: inherit;
    letter-spacing: inherit;
  }

  .footer-credit {
    text-decoration: none;
    color: var(--ink);
    transition: color 280ms cubic-bezier(0.65, 0, 0.35, 1);
  }

  .footer-credit:hover {
    color: var(--ink-mute);
  }

  /* ============================================================
     Responsive — stack the grid below ~820px
     ============================================================ */
  @media (max-width: 820px) {
    .footer {
      padding: 56px 20px 24px;
    }
    .footer-pitch {
      margin-top: 32px;
    }
    .footer-cta {
      margin-top: 32px;
    }
    /* Tablet: stack each group as 50% wide, nav-pair sub-grid
       still keeps its tight pair gap. */
    .footer-grid {
      flex-wrap: wrap;
      gap: 40px;
      margin-top: 48px;
    }
    .footer-grid > .footer-col,
    .footer-nav-pair {
      flex: 0 0 calc(50% - 20px);
    }
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
      margin-top: 48px;
    }
  }

  @media (max-width: 480px) {
    .footer-grid > .footer-col,
    .footer-nav-pair {
      flex: 0 0 100%;
    }
    .footer-grid {
      gap: 32px;
    }
  }
</style>
