---
/**
 * Works (Section 3 — "Výber prác") — selected projects grid.
 *
 * Figma spec (node 2653:229):
 *   - Container: 1384px wide, py 80px, page-edge 28px gutters
 *   - Top label: "Výber našich prác", Switzer Medium 16px #222
 *   - 3 rows with asymmetric horizontal offsets (8.45% = 117/1384
 *     "breathing" indents) that break the grid:
 *       Row 1: [445 flush left] ... gap ... [680 — 117 inward right]
 *       Row 2: [563 — 117 inward left] ... gap ... [563 flush right]
 *       Row 3: [445 flush left] ... gap ... [800 flush right]
 *           (closing panorama — wider than the others)
 *   - 80px row gap between rows
 *   - Each tile: image on top, 20px gap, title (Switzer Medium
 *     20px #222) + 8px + description (Switzer Regular 16px #666,
 *     line-height 22px verified from Figma).
 *   - Bottom CTA "Ďalšie projekty" — same dark 211×p12 button as
 *     About/Hero, centered.
 *
 * Motion is wired in scripts/works.ts:
 *   - Inner parallax on every tile (±8 yPercent on image)
 *   - Row 1 paired clip-path reveal (curtain rising, 150ms stagger)
 *   - Per-tile text stagger reveal (title → desc, 80ms gap)
 *   - Hover image scale 1.04 + cursor "POZRIEŤ" state
 */

interface Project {
  title: string;
  description: string;
  image: string;
  alt: string;
}

import { home, type Lang } from "../i18n/home";

interface Props {
  lang?: Lang;
}
const { lang = "sk" } = Astro.props;
const t = home[lang];

// Images are language-agnostic; titles / descriptions / alt come from
// the i18n dictionary (home.ts → works.projects), zipped together in
// the same order the grid renders them.
const images = [
  "/images/works/work-1.jpg",
  "/images/works/work-2.jpg",
  "/images/works/work-3.jpg",
  "/images/works/work-4.jpg",
  "/images/works/work-5.jpg",
  "/images/works/work-6.jpg",
];
const projects: Project[] = t.works.projects.map((p, i) => ({
  ...p,
  image: images[i],
}));
---

<section class="works" id="projekty" aria-labelledby="works-heading">
  <p class="works-label" id="works-heading">{t.works.label}</p>

  <div class="works-grid">
    {/* Row 1 — small left hugs page edge, big right pulls inward
        by ~117px (8.45% of grid). Asymmetric "zig". */}
    <div class="works-row works-row--1">
      <article class="work-tile work-tile--r1l">
        <div class="work-media">
          <img src={projects[0].image} alt={projects[0].alt} loading="lazy" />
        </div>
        <div class="work-info">
          <h3 class="work-title" data-reveal>{projects[0].title}</h3>
          <p class="work-desc" data-reveal>{projects[0].description}</p>
        </div>
      </article>
      <article class="work-tile work-tile--r1r">
        <div class="work-media">
          <img src={projects[1].image} alt={projects[1].alt} loading="lazy" />
        </div>
        <div class="work-info">
          <h3 class="work-title" data-reveal>{projects[1].title}</h3>
          <p class="work-desc" data-reveal>{projects[1].description}</p>
        </div>
      </article>
    </div>

    {/* Row 2 — inverse zig: left tile pulled inward by ~117px from
        the left edge, right tile (Bistro) hugs the page edge.
        Bistro is now the lone tile reaching the right edge in the
        whole section — stands out instead of aligning with Vila. */}
    <div class="works-row works-row--2">
      <article class="work-tile work-tile--r2l">
        <div class="work-media">
          <img src={projects[2].image} alt={projects[2].alt} loading="lazy" />
        </div>
        <div class="work-info">
          <h3 class="work-title" data-reveal>{projects[2].title}</h3>
          <p class="work-desc" data-reveal>{projects[2].description}</p>
        </div>
      </article>
      <article class="work-tile work-tile--r2r">
        <div class="work-media">
          <img src={projects[3].image} alt={projects[3].alt} loading="lazy" />
        </div>
        <div class="work-info">
          <h3 class="work-title" data-reveal>{projects[3].title}</h3>
          <p class="work-desc" data-reveal>{projects[3].description}</p>
        </div>
      </article>
    </div>

    {/* Row 3 — mirrors Row 1's zig: small left hugs page edge,
        big right pulls inward. Closes the section with the same
        rhythm as the opener. */}
    <div class="works-row works-row--3">
      <article class="work-tile work-tile--r3l">
        <div class="work-media">
          <img src={projects[4].image} alt={projects[4].alt} loading="lazy" />
        </div>
        <div class="work-info">
          <h3 class="work-title" data-reveal>{projects[4].title}</h3>
          <p class="work-desc" data-reveal>{projects[4].description}</p>
        </div>
      </article>
      <article class="work-tile work-tile--r3r">
        <div class="work-media">
          <img src={projects[5].image} alt={projects[5].alt} loading="lazy" />
        </div>
        <div class="work-info">
          <h3 class="work-title" data-reveal>{projects[5].title}</h3>
          <p class="work-desc" data-reveal>{projects[5].description}</p>
        </div>
      </article>
    </div>
  </div>

  <a class="works-cta" href="#projekty">
    <span class="works-cta-text">{t.works.cta}</span>
    <svg
      class="works-cta-arrow"
      width="16"
      height="10"
      viewBox="0 0 16 10"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M0 5 H14 M10 1 L14 5 L10 9" />
    </svg>
  </a>
</section>

<style>
  /* =============================================================
     Container — 1384px content frame inside the 1440 canvas
     (28px gutters left/right), 80px vertical breathing room.
     ============================================================= */
  .works {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    /* 32px controls label → grid (tight coupling, label belongs to
       the grid). Grid → CTA spacing is widened to 48px via an
       explicit margin-top on .works-cta below. */
    gap: clamp(24px, 2.22vw, 48px);
    width: 100%;
    /* 2464 = 2560 - 2*48 gutter. Section fills the viewport up to
       2560 width with growing 28→48px gutters, then caps and
       centers within bigger displays. */
    max-width: 2464px;
    margin: 0 auto;
    /* py: 80 at 1440 (Figma py-80) — caps at 80 above 1440.
       px: 28 at 1440 → 48 at 2400+ (clamps).
       Equal top & bottom padding per Figma spec. */
    padding: clamp(48px, 5.55vw, 80px) clamp(16px, 2vw, 48px);
    background: var(--bg);
  }

  /* ===== Top label ===== */
  .works-label {
    width: 100%;
    font-family: var(--font-sans);
    font-weight: 500;
    /* 16 at 1440 → 24 at 2160+. Scales with viewport. */
    font-size: clamp(14px, 1.11vw, 24px);
    line-height: normal;
    color: var(--ink);
    margin: 0;
  }

  /* ===== Grid ===== */
  .works-grid {
    display: flex;
    flex-direction: column;
    /* 80 at 1440 → 120 at 2160+. */
    gap: clamp(56px, 5.55vw, 120px);
    width: 100%;
  }

  /* Each row uses justify-content: space-between with no explicit
     gap. Tile widths + asymmetric margins (margin-left or margin-
     right on individual tiles) consume specific shares of the row;
     the remaining space auto-distributes as the gap between tiles.
     This matches the Figma "broken grid" composition where every
     row has its own breathing pattern. */
  .works-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    width: 100%;
  }

  /* ===== Tile =====
     Image and text are a single unit — keep them tightly coupled
     (20px at 1440 → 30 at 2160+) so the caption reads as belonging
     to the photo, not as a separate paragraph below it. */
  .work-tile {
    display: flex;
    flex-direction: column;
    gap: clamp(16px, 1.39vw, 30px);
  }

  /* Tile widths and margins are expressed as percentages of the
     1384px grid so they scale proportionally between 1024 and 1440
     while preserving exact Figma pixel dimensions at the desktop
     canvas. The 117/1384 = 8.45% offsets are the "breathing rooms"
     that break alignment between rows.

     OFFSET MAP
       Row 1: [445 flush left] ... gap ... [680 — 117 inward right]
       Row 2: [563 — 117 inward left] ... gap ... [563 flush right]
       Row 3: [445 flush left] ... gap ... [800 flush right, panoramic]

     Right-edge rhythm escalates: Row 1 right indented → Row 2 right
     anchors at edge → Row 3 right anchors at edge AND grows wider
     (cinematic closing chord). */

  /* All .work-media frames use aspect-ratio (not fixed px height)
     so they grow proportionally when the section width grows
     beyond the 1440 baseline. Aspect numerators/denominators come
     from the Figma px dimensions at 1440 — the ratio stays exact
     at any viewport. */

  /* Row 1 left — small portrait, hugs left edge. */
  .work-tile--r1l {
    flex: 0 0 calc(445 / 1384 * 100%);
    min-width: 0;
  }
  .work-tile--r1l .work-media {
    aspect-ratio: 445 / 478;
  }

  /* Row 1 right — large tile pulled inward from the right edge by
     117/1384. Vila Na kopci then ends at ~1267 not 1384. */
  .work-tile--r1r {
    flex: 0 0 calc(680 / 1384 * 100%);
    min-width: 0;
    margin-right: calc(117 / 1384 * 100%);
  }
  .work-tile--r1r .work-media {
    aspect-ratio: 680 / 698;
  }

  /* Row 2 left — tall portrait pulled inward from the LEFT edge.
     Starts at ~117 instead of 0. */
  .work-tile--r2l {
    flex: 0 0 calc(563 / 1384 * 100%);
    min-width: 0;
    margin-left: calc(117 / 1384 * 100%);
  }
  .work-tile--r2l .work-media {
    aspect-ratio: 563 / 730;
  }

  /* Row 2 right — short landscape, hugs the right edge. The only
     tile in the whole section that reaches 1384, which makes it
     stand out instead of aligning with Vila above. */
  .work-tile--r2r {
    flex: 0 0 calc(563 / 1384 * 100%);
    min-width: 0;
  }
  .work-tile--r2r .work-media {
    aspect-ratio: 563 / 402;
  }

  /* Row 3 left — mid-portrait, mirrors Row 1 left's width but
     taller. 445 × 540 = 0.82 aspect (slight portrait, balances
     the panoramic Knižnica on the right without competing). */
  .work-tile--r3l {
    flex: 0 0 calc(445 / 1384 * 100%);
    min-width: 0;
  }
  .work-tile--r3l .work-media {
    aspect-ratio: 445 / 540;
  }

  /* Row 3 right — section closer, anchored at the right page edge.
     800 × 400 = 2:1 univisium ratio. Cinematic but not letterbox —
     enough vertical room for Knižnica's perspective lines, stairs,
     and bookshelf verticality to read properly. ~1.40× Ateliér's
     visual mass keeps the hierarchy clear without overwhelming. */
  .work-tile--r3r {
    flex: 0 0 calc(800 / 1384 * 100%);
    min-width: 0;
  }
  .work-tile--r3r .work-media {
    aspect-ratio: 800 / 400;
  }

  /* ===== Image frame =====
     overflow: hidden clips the oversized image as it parallaxes
     up and down within the frame, and also clips the 1.04 hover
     scale to the tile's bounds. */
  .work-media {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: var(--surface); /* faint placeholder before image paints */
  }

  /* Image is 122% of frame height with top:-11% — extra 22% of
     vertical headroom (11% on each side) is the room the parallax
     has to drift. yPercent ±8 = 8% of image height = 9.76% of
     frame, well inside the 11% headroom (~1.24% safety buffer at
     each extreme). will-change promotes the layer to the GPU so
     the scrub stays buttery. */
  .work-media img {
    position: relative;
    top: -11%;
    width: 100%;
    height: 122%;
    object-fit: cover;
    display: block;
    will-change: transform;
  }

  /* ===== Text block ===== */
  .work-info {
    display: flex;
    flex-direction: column;
    /* 8 at 1440 → 12 at 2160+. */
    gap: clamp(6px, 0.56vw, 12px);
    width: 100%;
  }

  .work-title {
    font-family: var(--font-sans);
    font-weight: 500;
    font-style: normal;
    /* 20 at 1440 → 30 at 2160+. */
    font-size: clamp(18px, 1.39vw, 30px);
    line-height: 1.1;
    letter-spacing: 0.02em;
    color: var(--ink);
    margin: 0;
    /* Both reveal (translateY via GSAP) and hover (translateX via
       GSAP) are JS-driven so they share one transform channel
       without a CSS transition fighting them. */
    will-change: transform, opacity;
  }

  /* Initial pre-reveal state — declared in CSS (not GSAP) so the
     text is hidden from the very first paint, even before
     works.ts runs. Prevents the 1-frame flash where unstyled text
     would be visible at full opacity before the animation begins.
     The reveal in works.ts removes this offset. */
  .work-title[data-reveal],
  .work-desc[data-reveal] {
    opacity: 0;
    transform: translateY(16px);
  }

  .work-desc {
    font-family: var(--font-sans);
    font-weight: 400;
    /* 16 at 1440 → 22 at 1980+. */
    font-size: clamp(14px, 1.11vw, 22px);
    /* Unitless 1.375 = 22/16 — keeps line-height proportional to
       font-size at any viewport so description boxes still land
       on whole-number heights at the design baseline. */
    line-height: 1.375;
    letter-spacing: 0.02em;
    color: var(--text-mute);
    margin: 0;
    will-change: transform, opacity;
  }

  /* ===== CTA — mirrors the About / Hero CTA pattern =====
     margin-top (16px) adds to the parent's `gap: 32px` so the
     visual distance from the grid bottom to the CTA is 48px. */
  .works-cta {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(10px, 0.83vw, 12px);
    /* Figma spec 211×44 px — clamps cap at those values so the
       button never grows past spec above 1440. */
    width: clamp(180px, 14.65vw, 211px);
    margin-top: clamp(12px, 1.11vw, 24px);
    padding: clamp(10px, 0.97vw, 14px) clamp(12px, 1.11vw, 16px);
    background: var(--btn-bg);
    color: var(--btn-fg);
    text-decoration: none;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(14px, 1.11vw, 16px);
    line-height: 1;
    letter-spacing: 0.02em;
    overflow: hidden;
    will-change: transform;
  }

  .works-cta::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--btn-bg-hover);
    transform: translateX(-101%);
    transition: transform 520ms cubic-bezier(0.65, 0, 0.35, 1);
    will-change: transform;
    z-index: 0;
  }

  .works-cta:hover::before {
    transform: translateX(0);
  }

  .works-cta > * {
    position: relative;
    z-index: 1;
  }

  .works-cta-text {
    display: inline-block;
    transition: transform 420ms cubic-bezier(0.65, 0, 0.35, 1);
    will-change: transform;
  }

  .works-cta:hover .works-cta-text {
    transform: translateX(3px);
  }

  .works-cta-arrow {
    display: block;
    flex: 0 0 auto;
    transition: transform 440ms cubic-bezier(0.65, 0, 0.35, 1);
    will-change: transform;
  }

  .works-cta:hover .works-cta-arrow {
    transform: translateX(7px);
  }

  /* =============================================================
     Responsive
     -----------------------------------------------------------------
     TABLET (768–1199): no rule. The percentage flex-bases + clamp()
     values above scale the broken grid down proportionally — the
     "scaled-down desktop" approach (studiodado-style).

     MOBILE (≤767): the dedicated Figma layout — a single-column
     stack of cards (square image, 20px gap, name 20px / desc 16px).
     Asymmetric margins are dropped; every tile is full width.
     ============================================================= */
  @media (max-width: 767px) {
    .works {
      gap: 24px;
      padding: 56px 16px;
    }
    .works-grid {
      gap: 48px;
    }
    .works-row {
      flex-direction: column;
      align-items: stretch;
      justify-content: flex-start;
      gap: 48px;
    }
    .work-tile--r1l,
    .work-tile--r1r,
    .work-tile--r2l,
    .work-tile--r2r,
    .work-tile--r3l,
    .work-tile--r3r {
      flex: none;
      width: 100%;
      height: auto;
      margin: 0;
    }
    /* Figma mobile cards read as near-square (361×368). Image → info
       gap 20px, info gap 8px (Figma Project Info spec). */
    .work-tile {
      gap: 20px;
    }
    .work-tile--r1l .work-media,
    .work-tile--r1r .work-media,
    .work-tile--r2l .work-media,
    .work-tile--r2r .work-media,
    .work-tile--r3l .work-media,
    .work-tile--r3r .work-media {
      flex: none;
      height: auto;
      aspect-ratio: 1 / 1;
    }
    /* iOS Safari doesn't reliably resolve the percentage `top: -11%`
       against the aspect-ratio media height, so the image sat flush at the
       top and the ±8% inner parallax exposed a grey strip on scroll. Give
       the headroom via margin-top instead — margin percentages resolve
       against WIDTH (always definite), and the mobile tile is square so
       -11% width == -11% height. Same parallax (±8), reliable on WebKit.
       top:0 neutralises the base rule on engines where it does resolve, so
       the offset is never doubled. */
    .work-media img {
      top: 0;
      margin-top: -11%;
    }
    .work-info {
      gap: 8px;
    }
    .work-title {
      font-size: 20px;
      line-height: 1.1;
    }
    .work-desc {
      font-size: 16px;
      line-height: 1.375;
    }
  }
</style>
