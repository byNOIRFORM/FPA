---
/**
 * Nav — the single, shared navigation used across the whole site
 * (landing hero + every subpage). One source of truth for markup,
 * styles and behaviour so the bar can never drift apart between pages
 * again. Behaviour (theme-switch on scroll + auto-hide) lives in one
 * place: scripts/nav.ts, called once from BaseLayout.
 *
 * Variants:
 *   - "home" — landing: in-page anchors, starts hidden (.nav-animate)
 *     and is revealed by the loader (hero.ts → revealHero).
 *   - "sub"  — subpages (e.g. /sluzby): anchors point back to the
 *     homepage, the nav is visible from first paint (no loader), and
 *     the current page's link is de-emphasised via `active`.
 *
 * `boundary` is the selector the theme-switch observes: while it is in
 * view the nav is transparent (over the hero/photo); once it scrolls
 * past the top the nav becomes the cream panel. Defaults per variant.
 */
import { home, langHref, langLabel, LANGS, localizedHrefs, servicesHref, type Lang } from "../i18n/home";

interface Props {
  lang?: Lang;
  variant?: "home" | "sub";
  active?: "about" | "projects" | "services";
  boundary?: string;
}

const {
  lang = "sk",
  variant = "home",
  active,
  boundary = variant === "home" ? ".hero" : ".sintro",
} = Astro.props;

const t = home[lang];

// SK/CZ/EN switch keeps you on the CURRENT page in the other language
// (computed from the URL), instead of always bouncing to the homepage.
const langHrefs = localizedHrefs(Astro.url.pathname);

// Subpage anchors jump back to the current language's homepage; landing
// anchors are local. Services points at the current language's subpage.
const homeBase = variant === "home" ? "" : lang === "sk" ? "/" : `/${lang}`;
const aboutHref = `${homeBase}#o-nas`;
const projectsHref = `${homeBase}#projekty`;
const servicesLink = servicesHref[lang];

// Only the landing nav starts hidden for the loader reveal — subpages
// have no loader, so their nav must paint visible.
const anim = variant === "home" ? " nav-animate" : "";
const activeCls = (key: NonNullable<Props["active"]>) =>
  active === key ? " nav-link--active" : "";
const ariaCur = (key: NonNullable<Props["active"]>) =>
  active === key ? "page" : undefined;
---

<nav class="nav" aria-label="Hlavná navigácia" data-nav-boundary-target={boundary}>
  <div class="nav-left">
    <a class={`nav-logo${anim}`} href={langHref[lang]} data-grid-trigger>
      <span class="nav-logo-main">FOTTA//POPADIČ</span>
      <span class="nav-logo-sub">architekt</span>
    </a>
    <span class={`nav-clock${anim}`} data-clock>Bardejov --:--</span>
  </div>

  <ul class={`nav-langs${anim}`} aria-label="Jazyk">
    {LANGS.map((l) => (
      <li>
        <a
          href={langHrefs[l]}
          class={`nav-flip nav-lang${l === lang ? " nav-lang--active" : ""}`}
          data-text={langLabel[l]}
          aria-current={l === lang ? "true" : undefined}
        >
          <span>{langLabel[l]}</span>
        </a>
      </li>
    ))}
  </ul>

  <div class="nav-right">
    <ul class={`nav-links${anim}`}>
      <li><a class={`nav-flip${activeCls("about")}`} href={aboutHref} data-text={t.nav.links.about} aria-current={ariaCur("about")}><span>{t.nav.links.about}</span></a></li>
      <li><a class={`nav-flip${activeCls("projects")}`} href={projectsHref} data-text={t.nav.links.projects} aria-current={ariaCur("projects")}><span>{t.nav.links.projects}</span></a></li>
      <li><a class={`nav-flip${activeCls("services")}`} href={servicesLink} data-text={t.nav.links.services} aria-current={ariaCur("services")}><span>{t.nav.links.services}</span></a></li>
    </ul>
    <a class={`nav-cta${anim}`} href="#kontakt" data-open-contact>
      <span class="nav-cta-text">{t.nav.cta}</span>
      <svg
        class="nav-cta-arrow"
        width="16"
        height="10"
        viewBox="0 0 16 10"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M0 5 H14 M10 1 L14 5 L10 9" />
      </svg>
    </a>
  </div>

  <button class={`nav-menu${anim}`} type="button" data-open-menu aria-label={t.nav.menuAria}>
    <span class="nav-flip" data-text={t.nav.menu}><span>{t.nav.menu}</span></span>
  </button>
</nav>

<style>
  /* ===== Bar =====
     Fixed to the viewport. Transparent + white text over the hero/photo;
     the .is-scrolled state (toggled in scripts/nav.ts) swaps to the cream
     panel once the boundary element has scrolled past the top. The
     hide/show transform is GSAP-driven (auto-hide); these CSS transitions
     only cover the theme swap. */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(24px, 3.33vw, 72px);
    padding: clamp(16px, 1.53vw, 33px) clamp(16px, 2vw, 48px);
    color: #fff;
    background: transparent;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(14px, 1.11vw, 22px);
    line-height: 1;
    letter-spacing: 0.02em;
    will-change: transform;
    transition:
      background 420ms cubic-bezier(0.65, 0, 0.35, 1),
      color 420ms cubic-bezier(0.65, 0, 0.35, 1),
      box-shadow 420ms cubic-bezier(0.65, 0, 0.35, 1),
      padding 420ms cubic-bezier(0.65, 0, 0.35, 1);
  }

  .nav.is-scrolled {
    background: var(--bg);
    color: var(--ink);
    padding: clamp(12px, 1.11vw, 24px) clamp(16px, 2vw, 48px);
  }

  .nav-left {
    display: flex;
    align-items: center;
    gap: clamp(40px, 5.55vw, 120px);
  }

  .nav-logo {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
    text-decoration: none;
    color: inherit;
    line-height: 1;
  }

  .nav-logo-main {
    font-size: clamp(20px, 1.67vw, 36px);
    font-weight: 600;
    letter-spacing: 0.02em;
    line-height: 1;
    transition: font-size 420ms cubic-bezier(0.65, 0, 0.35, 1);
  }

  .nav-logo-sub {
    font-size: clamp(20px, 1.67vw, 36px);
    font-style: italic;
    font-weight: 400;
    letter-spacing: 0.02em;
    line-height: 1;
    transition: font-size 420ms cubic-bezier(0.65, 0, 0.35, 1);
  }

  .nav.is-scrolled .nav-logo-main,
  .nav.is-scrolled .nav-logo-sub {
    font-size: clamp(18px, 1.39vw, 30px);
  }

  .nav-clock {
    font-size: clamp(14px, 1.11vw, 22px);
    font-weight: 500;
    letter-spacing: 0.02em;
    line-height: 1;
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  .nav-langs {
    display: flex;
    gap: clamp(10px, 0.83vw, 18px);
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-lang {
    color: inherit;
    text-decoration: none;
  }

  /* Current language — de-emphasised + inert, exactly like the active
     page link (.nav-link--active). */
  .nav-lang--active {
    opacity: 0.55;
    pointer-events: none;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: clamp(40px, 5.55vw, 120px);
  }

  .nav-links {
    display: flex;
    gap: clamp(10px, 0.83vw, 18px);
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    color: inherit;
    text-decoration: none;
    line-height: 1;
    display: inline-block;
  }

  /* Current-page link (subpage variant) — de-emphasised + inert. */
  .nav-link--active {
    opacity: 0.55;
    pointer-events: none;
  }

  /* Text flip hover — visible text slides up, a duplicate (::after,
     content: attr(data-text)) rises from below. Pure CSS. */
  .nav-flip {
    position: relative;
    display: inline-block;
    overflow: hidden;
    line-height: 1.15;
    vertical-align: top;
    color: inherit;
    text-decoration: none;
  }

  .nav-flip span {
    display: inline-block;
    transition: transform 480ms cubic-bezier(0.65, 0, 0.35, 1);
    will-change: transform;
  }

  .nav-flip::after {
    content: attr(data-text);
    position: absolute;
    left: 0;
    top: 100%;
    transition: transform 480ms cubic-bezier(0.65, 0, 0.35, 1);
    will-change: transform;
  }

  .nav-flip:hover span,
  .nav-flip:hover::after {
    transform: translateY(-100%);
  }

  .nav-cta {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(10px, 0.83vw, 12px);
    width: clamp(180px, 14.65vw, 211px);
    padding: clamp(10px, 0.97vw, 14px) clamp(12px, 1.11vw, 16px);
    background: var(--btn-bg);
    color: var(--btn-fg);
    text-decoration: none;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(14px, 1.11vw, 16px);
    line-height: 1;
    letter-spacing: 0.02em;
    overflow: hidden;
  }

  .nav-cta::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--btn-bg-hover);
    transform: translateX(-101%);
    transition: transform 520ms cubic-bezier(0.65, 0, 0.35, 1);
    will-change: transform;
    z-index: 0;
  }

  .nav-cta:hover::before {
    transform: translateX(0);
  }

  .nav-cta > * {
    position: relative;
    z-index: 1;
  }

  .nav-cta-text {
    display: inline-block;
    color: var(--btn-fg);
    line-height: 1;
    transition: transform 420ms cubic-bezier(0.65, 0, 0.35, 1);
    will-change: transform;
  }

  .nav-cta:hover .nav-cta-text {
    transform: translateX(3px);
  }

  .nav-cta-arrow {
    display: block;
    flex: 0 0 auto;
    color: var(--btn-fg);
    transition: transform 440ms cubic-bezier(0.65, 0, 0.35, 1);
    will-change: transform;
  }

  .nav-cta:hover .nav-cta-arrow {
    transform: translateX(7px);
  }

  /* ===== Mobile menu trigger — hidden until ≤767px ===== */
  .nav-menu {
    display: none;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 16px;
    line-height: 22px;
    letter-spacing: 0.02em;
    color: inherit;
    background: none;
    border: 0;
    padding: 4px 0;
    cursor: pointer;
  }

  /* ===== Loader reveal initial state (home variant only — the
     .nav-animate class is only emitted there). Cleared by revealHero. */
  .nav-animate {
    opacity: 0;
    transform: translateY(-12px);
    will-change: transform, opacity;
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-animate {
      transform: none;
      opacity: 1;
    }
    .nav-flip span,
    .nav-flip::after {
      transition: none;
    }
  }

  /* ===== Tablet (768–1199) — scaled-down desktop nav ===== */
  @media (min-width: 768px) and (max-width: 1199px) {
    .nav {
      gap: clamp(20px, 3vw, 48px);
    }
    .nav-left,
    .nav-right {
      gap: clamp(24px, 3.5vw, 56px);
    }
    .nav-clock {
      display: none;
    }
    .nav-cta {
      width: auto;
    }
  }

  /* ===== Mobile (≤767) — logo + Menu only ===== */
  @media (max-width: 767px) {
    .nav {
      gap: 16px;
      padding: calc(16px + env(safe-area-inset-top, 0px)) 16px 16px;
      align-items: flex-start;
    }
    .nav.is-scrolled {
      padding: calc(16px + env(safe-area-inset-top, 0px)) 16px 16px;
    }
    .nav-clock,
    .nav-langs,
    .nav-links,
    .nav-cta {
      display: none;
    }
    .nav-menu {
      display: inline-block;
    }
    .nav-logo-main,
    .nav-logo-sub,
    .nav.is-scrolled .nav-logo-main,
    .nav.is-scrolled .nav-logo-sub {
      font-size: 20px;
      line-height: 1;
    }
  }
</style>
