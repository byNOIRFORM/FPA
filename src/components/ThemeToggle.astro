---
/**
 * ThemeToggle — fixed light/dark switch pinned to the bottom-right.
 *
 * The actual theme is resolved before first paint by the inline script
 * in BaseLayout's <head>; this button just flips it afterwards
 * (theme-toggle.ts) and persists the choice to localStorage.
 *
 * A11y: a real <button> with an aria-label and aria-pressed (kept in
 * sync by the script). Both icons ship; CSS shows the one matching the
 * CURRENT theme — moon in light (→ go dark), sun in dark (→ go light).
 */
import type { Lang } from "../i18n/home";

interface Props {
  lang?: Lang;
}
const { lang = "sk" } = Astro.props;

const label: Record<Lang, string> = {
  sk: "Prepnúť tmavý režim",
  cz: "Přepnout tmavý režim",
  en: "Toggle dark mode",
};
---

<button
  class="theme-toggle"
  type="button"
  data-theme-toggle
  aria-label={label[lang]}
  aria-pressed="false"
  title={label[lang]}
>
  {/* Moon — shown in light mode (click to go dark) */}
  <svg
    class="theme-toggle-icon theme-toggle-moon"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.6"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8Z" />
  </svg>

  {/* Sun — shown in dark mode (click to go light) */}
  <svg
    class="theme-toggle-icon theme-toggle-sun"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.6"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
  </svg>
</button>

<style>
  .theme-toggle {
    position: fixed;
    right: clamp(16px, 1.8vw, 28px);
    bottom: clamp(16px, 1.8vw, 28px);
    z-index: 900;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--surface);
    color: var(--ink);
    border: 1px solid var(--line);
    cursor: pointer;
    /* Custom cursor is hidden over interactive controls on desktop;
       restore the system pointer here so the control feels native. */
    transition:
      background 280ms var(--ease-in-out),
      color 280ms var(--ease-in-out),
      border-color 280ms var(--ease-in-out),
      transform 280ms var(--ease-in-out);
  }

  .theme-toggle:hover {
    transform: translateY(-2px);
    border-color: var(--ink);
  }

  .theme-toggle:focus-visible {
    outline: 2px solid var(--ink);
    outline-offset: 3px;
  }

  .theme-toggle-icon {
    position: absolute;
    transition:
      opacity 240ms var(--ease-in-out),
      transform 360ms var(--ease-in-out);
  }

  /* Show the icon that represents the action available in the CURRENT
     theme: moon while light (go dark), sun while dark (go light). */
  .theme-toggle-sun {
    opacity: 0;
    transform: rotate(-40deg) scale(0.6);
  }
  .theme-toggle-moon {
    opacity: 1;
    transform: rotate(0) scale(1);
  }

  :global([data-theme="dark"]) .theme-toggle-sun {
    opacity: 1;
    transform: rotate(0) scale(1);
  }
  :global([data-theme="dark"]) .theme-toggle-moon {
    opacity: 0;
    transform: rotate(40deg) scale(0.6);
  }

  /* Hidden on touch devices — same convention as the custom cursor;
     mobile users get the OS theme. Keep it on for now (controllable),
     but tuck it a little higher so it clears mobile browser UI. */
  @media (max-width: 767px) {
    .theme-toggle {
      /* Clear the home indicator now that viewport-fit=cover lets content
         run under it (env is 0 on devices without a safe area). */
      bottom: calc(20px + env(safe-area-inset-bottom, 0px));
      right: 16px;
      width: 42px;
      height: 42px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .theme-toggle,
    .theme-toggle-icon {
      transition: none;
    }
  }
</style>
