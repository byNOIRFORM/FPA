---
/**
 * Leaders (Section 4 — "Lídri ateliéru") — founders cards row.
 *
 * Figma spec (node 2918:1794):
 *   - Manifest text: Switzer Medium 48px / lh 60 / tracking 0.96
 *     left-aligned, max-width 1384. Per-word color scrub from
 *     #C8C8C8 → #222 (same pattern as About headline).
 *   - Eyebrow "Lídri ateliéru": Switzer Medium label, same clamp
 *     as Works/Services labels (16 at 1440).
 *   - 3 leader cards (Pavol, Dominik, Tomáš), each 328×470 image
 *     + 20px gap + name (20px) + 8px + description (16px #666),
 *     matching Works tile typography exactly.
 *   - Cards grid is RIGHT-aligned within the 1384 inner width
 *     (asymmetric composition, intentional).
 *   - 142px gaps between cards.
 *   - Bottom CTA "Dozvedieť sa viac" — same dark 211×p12 button
 *     pattern as the other sections, centred.
 *
 * Motion wired in scripts/leaders.ts:
 *   - Manifest words scrub color #C8C8C8 → #222 (mirrors About).
 *   - Cards cascade reveal L→R as the grid enters viewport:
 *     each card runs photo curtain (clip-path inset 100% → 0)
 *     + text fade-up (name → desc), staggered 0.2s between cards.
 *   - Inner parallax on each photo (±8 yPercent on scroll) —
 *     same calibration as Works tiles and Services rows.
 */

interface Leader {
  name: string;
  desc: string;
  image: string;
  alt: string;
}

import { home, type Lang } from "../i18n/home";

interface Props {
  lang?: Lang;
}
const { lang = "sk" } = Astro.props;
const t = home[lang];

// Founder names + portraits are language-agnostic and stay here;
// descriptions and alt come from the i18n dictionary (home.ts →
// leaders.people), zipped in render order.
const meta = [
  { name: "Ing. Pavol Fotta", image: "/images/leaders/pavol-fotta.jpg" },
  { name: "Dominik Fotta", image: "/images/leaders/dominik-fotta.jpg" },
  { name: "Ing. arch. Ing. Tomáš Popadič", image: "/images/leaders/tomas-popadic.jpg" },
];
const leaders: Leader[] = t.leaders.people.map((p, i) => ({ ...meta[i], ...p }));

// Manifest broken into per-word spans for the color-scrub
// animation (same pattern as About section). Split by whitespace
// preserves punctuation inside each word ("generácie,").
const manifestWords = t.leaders.manifest.split(" ");
---

<section class="leaders" id="lidri" aria-labelledby="leaders-heading">
  <p class="leaders-manifest" id="leaders-heading">
    {
      manifestWords.map((word, i) => (
        <>
          <span class="leaders-word">{word}</span>
          {i < manifestWords.length - 1 ? " " : ""}
        </>
      ))
    }
  </p>

  {/* Pin container — inside, the pin-wrap is position:sticky
      so it locks to viewport top for the container scroll.
      Eyebrow + cards live INSIDE the pin-wrap. The pin-wrap
      uses align-items:flex-end so the content sits at the
      BOTTOM of the pinned area — when sticky releases, the
      cards are exactly at the container's bottom edge, so the
      CTA below appears with the exact 48px gap (instead of a
      huge gap created by empty space below center-aligned
      content). */}
  <div class="leaders-pin-container">
    <div class="leaders-pin-wrap">
      <div class="leaders-pin-content">
        <p class="leaders-eyebrow">{t.leaders.eyebrow}</p>
        <div class="leaders-grid">
          {leaders.map((l, i) => (
            <article class="leader-card" data-leader={i}>
              <div class="leader-media">
                <img
                  src={l.image}
                  alt={l.alt}
                  loading={i === 0 ? "eager" : "lazy"}
                  decoding="async"
                />
              </div>
              <div class="leader-info">
                <h3 class="leader-name" data-reveal>{l.name}</h3>
                <p class="leader-desc" data-reveal>{l.desc}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>

  <a class="leaders-cta" href="#kontakt" data-open-contact>
    <span class="leaders-cta-text">{t.leaders.cta}</span>
    <svg
      class="leaders-cta-arrow"
      width="16"
      height="10"
      viewBox="0 0 16 10"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M0 5 H14 M10 1 L14 5 L10 9" />
    </svg>
  </a>

  {/* Closing divider — separates Leaders from Footer. */}
  <div class="leaders-divider" aria-hidden="true"></div>
</section>

<style>
  /* ===== Section frame =====
     Same outer padding / max-width as Works and Services so all
     three "documents" align to the same canvas. */
  .leaders {
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 2464px;
    margin: 0 auto;
    /* py-top: 80 at 1440 (Figma py-80 on the inner manifest
       container) — caps at 80 above 1440 for consistent rhythm
       with Works / Services / Footer.
       Bottom is 0 — Footer's top padding owns the gap below the
       divider. */
    padding: clamp(48px, 5.55vw, 80px) clamp(16px, 2vw, 48px) 0;
  }

  /* ===== Manifest =====
     Per-word color scrub anchored to viewport scroll. CSS keeps
     every word at --ink-faint by default; leaders.ts tweens
     color to var(--ink) with a per-word stagger. */
  /* Manifest container is LEFT-ALIGNED (margin: 0) so its left
     edge matches the Services content above. Only the FIRST
     line is indented with text-indent — the editorial opening
     for "Dve". Subsequent lines (and the second sentence after
     <br/>) flow flush to the container's left edge.
     3em ≈ 144px at the 48px Figma baseline, matching the
     ~11 spaces of indent shown in the Figma source. */
  .leaders-manifest {
    font-family: var(--font-sans);
    font-weight: 500;
    font-style: normal;
    font-size: clamp(28px, 3.33vw, 72px);
    line-height: 1.25;
    letter-spacing: 0.02em;
    color: var(--ink);
    text-align: left;
    width: 100%;
    max-width: 1384px;
    margin: 0;
    text-indent: 3em;
  }

  .leaders-word {
    color: var(--ink-faint);
    will-change: color;
  }

  /* ===== Eyebrow "Lídri ateliéru" =====
     80px below the manifest (matches Figma py-[80px] on the
     manifest wrapper). Same typographic register as
     .works-label / .services-label so all section labels
     speak with one voice. */
  /* Eyebrow LEFT-aligned (no max-width centering). Lives inside
     .leaders-pin-content now — the 40px gap between eyebrow and
     grid is handled by the pin-content's flex gap, so eyebrow
     itself needs no margin. */
  .leaders-eyebrow {
    font-family: var(--font-sans);
    font-weight: 500;
    font-style: normal;
    font-size: clamp(14px, 1.11vw, 24px);
    line-height: normal;
    letter-spacing: 0.02em;
    color: var(--ink);
    width: 100%;
    margin: 0;
  }

  /* ===== Pin container =====
     300vh tall — provides scroll space for the sticky pin scrub.
     margin-top: 0 because the 80px gap above the eyebrow
     (per Figma — manifest container has py-80) is owned by the
     pin-wrap's padding-top, so the spacing is identical whether
     the section is in initial scroll or actively pinned. */
  .leaders-pin-container {
    height: 300vh;
    position: relative;
    width: 100%;
    margin-top: 0;
  }

  /* ===== Pin wrap (CSS sticky) =====
     position: sticky locks this wrap to the top of the viewport
     for the container scroll. AUTO-HEIGHT so its bottom edge
     sits exactly under the cards — no empty sticky space
     inflating the visible gap to the CTA below.

     padding-top owns the 80px gap that Figma puts between the
     manifest text and the eyebrow (py-80 on the manifest
     container). Because it's a padding on the sticky wrap, the
     80px applies both when the section is in initial scroll
     (pushes eyebrow 80px below the manifest) AND during the
     pin (gives eyebrow 80px breathing from the viewport top). */
  .leaders-pin-wrap {
    position: sticky;
    top: 0;
    display: flex;
    flex-direction: column;
    padding-top: clamp(48px, 5.55vw, 80px);
    width: 100%;
  }

  /* ===== Pin content =====
     Stack of eyebrow + cards inside the pinned wrap.
     40px gap between eyebrow and grid (user-requested). */
  .leaders-pin-content {
    display: flex;
    flex-direction: column;
    gap: 40px;
    width: 100%;
  }

  /* ===== Cards grid =====
     Right-aligned grid with cards scaling proportionally to the
     viewport. All three cards in the SAME row inside the pinned
     wrap; sequencing is driven by the scroll-scrubbed timeline
     in leaders.ts. */
  .leaders-grid {
    display: grid;
    grid-template-columns: repeat(3, calc(328 / 1384 * 100%));
    gap: calc(142 / 1384 * 100%);
    justify-content: end;
    width: 100%;
  }

  /* ===== Card =====
     Pre-reveal state: opacity 0 + translated 80px below DOM
     position. The pinned timeline in leaders.ts reveals each
     card in sequence during the pin scroll. All cards in the
     same row — no Y stagger needed because the sequencing is
     done by the timeline, not by DOM position. */
  .leader-card {
    display: flex;
    flex-direction: column;
    gap: clamp(16px, 1.39vw, 30px);
    min-width: 0;
    opacity: 0;
    transform: translateY(80px);
    will-change: transform, opacity;
  }

  /* ===== Photo frame =====
     Aspect ratio 328:460 ≈ 0.71 (portrait). Figma spec is
     328:470; we shave 10px of height at the 1440 reference to
     give the pinned view a touch more breathing space at the
     bottom while keeping the wrap tall enough that the CTA
     (which sits 48px below the pin-container) never peeks
     into the viewport during the pin release.

     Initial clip-path hides the photo from below; leaders.ts
     scrubs it continuously based on scroll position — the
     curtain RISES as the user scrolls. */
  .leader-media {
    position: relative;
    aspect-ratio: 328 / 460;
    overflow: hidden;
    background: #efeeea;
    clip-path: inset(100% 0 0 0);
    will-change: clip-path;
  }

  .leader-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ===== Card text ===== */
  .leader-info {
    display: flex;
    flex-direction: column;
    gap: clamp(6px, 0.56vw, 12px);
    width: 100%;
  }

  /* Name uses the same .work-title clamp (20 at 1440 → 30 at
     2160+) so the card reads as a sibling of a Works tile. */
  .leader-name {
    font-family: var(--font-sans);
    font-weight: 500;
    font-style: normal;
    font-size: clamp(18px, 1.39vw, 30px);
    line-height: 1.1;
    letter-spacing: 0.02em;
    color: #222;
    margin: 0;
    will-change: transform, opacity;
  }

  /* Description uses the same .work-desc clamp (16 at 1440 →
     22 at 1980+) with proportional line-height. */
  .leader-desc {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(14px, 1.11vw, 22px);
    line-height: 1.375;
    letter-spacing: 0.02em;
    color: #666;
    margin: 0;
    will-change: transform, opacity;
  }

  /* ===== Reveal initial state (CSS-owned, pre-paint) ===== */
  .leader-name[data-reveal],
  .leader-desc[data-reveal] {
    opacity: 0;
    transform: translateY(16px);
  }

  /* ===== CTA — same pattern as Hero/About/Works/Services =====
     Lives in normal flow AFTER the pin-container. Always visible
     (no reveal animation). 48px margin-top — combined with the
     pin-wrap's align-items:flex-end + padding-bottom, the cards
     end at the container edge, so this 48px is the only space
     between cards bottom and CTA top. */
  .leaders-cta {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(10px, 0.83vw, 12px);
    width: clamp(180px, 14.65vw, 211px);
    margin-top: 48px;
    padding: clamp(10px, 0.97vw, 14px) clamp(12px, 1.11vw, 16px);
    background: #222;
    color: #fff;
    text-decoration: none;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(14px, 1.11vw, 16px);
    line-height: 1;
    letter-spacing: 0.02em;
    overflow: hidden;
    align-self: center;
    will-change: transform;
  }

  .leaders-cta::before {
    content: "";
    position: absolute;
    inset: 0;
    background: #000;
    transform: translateX(-101%);
    transition: transform 520ms cubic-bezier(0.65, 0, 0.35, 1);
    will-change: transform;
    z-index: 0;
  }

  .leaders-cta:hover::before {
    transform: translateX(0);
  }

  .leaders-cta > * {
    position: relative;
    z-index: 1;
  }

  .leaders-cta-text {
    display: inline-block;
    transition: transform 420ms cubic-bezier(0.65, 0, 0.35, 1);
    will-change: transform;
  }

  .leaders-cta:hover .leaders-cta-text {
    transform: translateX(3px);
  }

  .leaders-cta-arrow {
    display: block;
    flex: 0 0 auto;
    transition: transform 440ms cubic-bezier(0.65, 0, 0.35, 1);
    will-change: transform;
  }

  .leaders-cta:hover .leaders-cta-arrow {
    transform: translateX(7px);
  }

  /* ===== Closing divider =====
     Hairline edge-to-edge across the full inner width (no
     max-width / no centering) so it scales with the viewport
     like the rest of the section's content. */
  .leaders-divider {
    width: 100%;
    height: 1px;
    background: #a3a3a3;
    margin: clamp(40px, 5.55vw, 120px) 0 0;
  }

  /* ===== Reduced motion — snap all reveals to final state ===== */
  @media (prefers-reduced-motion: reduce) {
    .leaders-word {
      color: var(--ink);
    }
    .leaders-pin-container {
      height: auto;
    }
    .leaders-pin-wrap {
      position: static;
      height: auto;
    }
    .leader-card {
      opacity: 1;
      transform: none;
    }
    .leader-media {
      clip-path: inset(0% 0 0 0);
    }
    .leader-name[data-reveal],
    .leader-desc[data-reveal] {
      opacity: 1;
      transform: none;
    }
  }

  /* =============================================================
     Responsive
     -----------------------------------------------------------------
     TABLET (768–1199): no rule — the right-aligned 3-card grid +
     sticky pin scale down proportionally (scaled-down desktop). JS
     keeps the pin active here too (leaders.ts isMobile is also 767).

     MOBILE (≤767): disable the pin and stack the cards in a single
     centred column; each reveals on its own scroll trigger via the
     leaders.ts mobile fallback.
     ============================================================= */
  @media (max-width: 767px) {
    .leaders {
      padding: 56px 16px 0;
    }
    /* Editorial first-line indent reads as a typo on a narrow column. */
    .leaders-manifest {
      text-indent: 0;
    }
    .leaders-eyebrow {
      margin-top: 40px;
    }
    .leaders-pin-container {
      height: auto;
    }
    .leaders-pin-wrap {
      position: static;
      height: auto;
    }
    .leaders-grid {
      grid-template-columns: 1fr;
      gap: 40px;
      justify-content: stretch;
      max-width: none;
    }
    /* Match the Works/Figma mobile card typography. */
    .leader-card {
      gap: 20px;
    }
    .leader-info {
      gap: 8px;
    }
    .leader-name {
      font-size: 20px;
      line-height: 1.1;
    }
    .leader-desc {
      font-size: 16px;
      line-height: 1.375;
    }
  }
</style>
