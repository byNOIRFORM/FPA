---
/**
 * Services (Section 4 — "Služby") — selected services spec sheet.
 *
 * Figma spec (node 2886:1225):
 *   - Container: 1384px wide, py 80px, page-edge 28px gutters
 *   - Top label: "Služby" — Switzer Medium 24px, #222
 *   - 5 rows in a single column, each:
 *       [meta 327: num 01 + title]  [desc 445]  [media 328]
 *     joined by `justify-content: space-between`. Row height is
 *     driven by the tallest column (the media on portrait rows).
 *   - Vertical rhythm: rows 01 and 04 carry PORTRAIT photos
 *     (328×400, aspect ~4:5), rows 02/03/05 carry LANDSCAPE
 *     (328×193, aspect ~16:9). That asymmetric "TALL → short
 *     → short → TALL → short" heartbeat is the section's
 *     editorial signature — pure spec sheet typography would
 *     read flat without it.
 *   - 28px vertical padding per row; 1px #A3A3A3 hairline divider
 *     between rows. First row has no top padding; last row has no
 *     bottom border.
 *   - Bottom CTA "Dozvedieť sa viac" — same dark 211×p12 button
 *     pattern as Hero / About / Works, centred. Opens the contact
 *     panel via `data-open-contact` (consistent with nav CTA).
 *
 * Motion is wired in scripts/services.ts:
 *   - Row 01 photo: curtain clip-path reveal (inset 100% → 0) on
 *     first scroll-in, signature "section has begun" moment
 *   - All rows: per-row text stagger reveal (num → title → desc)
 *     as each enters viewport — prevents the "text pops in" jump
 *     that static rows showed when scrolling past
 *   - All photos: inner parallax ±8 yPercent on scroll (matches
 *     Works tiles)
 */

interface Service {
  num: string;
  title: string;
  desc: string;
  image: string;
  alt: string;
  /** Portrait rows are 328×400; landscape are 328×193. Drives
   *  the .service-media aspect-ratio CSS class. */
  aspect: "portrait" | "landscape";
  /** "Obsahuje" bullet list — only rendered in the `detailed` variant. */
  includes: string[];
}

import { home, type Lang } from "../i18n/home";
import ServiceDetail from "./ServiceDetail.astro";
import { detailIndices } from "../i18n/service-details";
import { servicesPage } from "../i18n/services-page";

interface Props {
  lang?: Lang;
  /** Detailed variant (the /sluzby page): adds the "Obsahuje" list +
   *  a per-row "Dozvedieť sa viac" link, drops the section label, and
   *  closes with a divider instead of the centred CTA. Same effects. */
  detailed?: boolean;
}
const { lang = "sk", detailed = false } = Astro.props;
const t = home[lang];
const sp = servicesPage[lang];

// num / image / aspect are language-agnostic and stay here; titles,
// descriptions and alt come from the i18n dictionary (home.ts →
// services.items), zipped in render order.
const meta = [
  { num: "01", image: "/images/services/01-urbanisticka.jpg", aspect: "portrait" as const },
  { num: "02", image: "/images/services/02-architektonicka.jpg", aspect: "landscape" as const },
  { num: "03", image: "/images/services/03-uzemne.jpg", aspect: "landscape" as const },
  { num: "04", image: "/images/services/04-stavebne.jpg", aspect: "portrait" as const },
  { num: "05", image: "/images/services/05-realizacna.jpg", aspect: "landscape" as const },
];

// "Obsahuje" lists for the detailed /sluzby variant come from the
// services-page dictionary (per language); the homepage summary ignores
// them. Row titles/descriptions still come from home.ts (services.items).
const services: Service[] = t.services.items.map((s, i) => ({
  ...meta[i],
  ...s,
  includes: sp.spec.includes[i],
}));
---

<section
  class={`services${detailed ? " services--detailed" : ""}`}
  id="sluzby"
  aria-label={detailed ? "Stupne projektovej dokumentácie" : undefined}
  aria-labelledby={detailed ? undefined : "services-heading"}
>
  {!detailed && <h2 class="services-label" id="services-heading">{t.services.label}</h2>}

  <ul class="services-list">
    {services.map((s, i) => (
      <li class={`service-row service-row--${i + 1}`}>
        <div class="service-row-inner">
          <div class="service-meta">
            <span class="service-num" data-reveal>{s.num}</span>
            <h3 class="service-title" data-reveal>{s.title}</h3>
          </div>
          <div class="service-desc" data-reveal>
            <p class="service-desc-text">{s.desc}</p>
            {detailed && s.includes.length > 0 && (
              <div class="service-includes">
                <p class="service-includes-label">{sp.spec.includesLabel}</p>
                <ul class="service-includes-list">
                  {s.includes.map((it) => <li>{it}</li>)}
                </ul>
              </div>
            )}
            {/* Per-row link — shown on every stage except Urbanistická
                štúdia (index 0). It opens the detail panel only where
                detail copy exists (i18n/service-details — just
                Architektonická štúdia for now); the rest are present but
                inert placeholders until their copy is written. */}
            {detailed && i > 0 && (
              <button
                type="button"
                class="service-more"
                data-open-detail={detailIndices.has(i) ? "" : undefined}
                data-detail-index={detailIndices.has(i) ? i : undefined}
              >
                <span>{t.services.cta}</span>
                <svg class="service-more-arrow" width="16" height="10" viewBox="0 0 16 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M0 5 H14 M10 1 L14 5 L10 9" />
                </svg>
              </button>
            )}
          </div>
          <div class={`service-media service-media--${s.aspect}`}>
            <img
              src={s.image}
              alt={s.alt}
              loading={i === 0 ? "eager" : "lazy"}
              decoding="async"
            />
          </div>
        </div>
      </li>
    ))}
  </ul>

  {/* Homepage summary — centred CTA to the /sluzby page. The detailed
      /sluzby variant has no bottom CTA/divider; the per-row links carry
      the action. */}
  {!detailed && (
    <a class="services-cta" href="/sluzby">
      <span class="services-cta-text">{t.services.cta}</span>
      <svg
        class="services-cta-arrow"
        width="16"
        height="10"
        viewBox="0 0 16 10"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M0 5 H14 M10 1 L14 5 L10 9" />
      </svg>
    </a>
  )}

  {/* Detailed variant closes with a hairline before the footer — mirrors
      the homepage Leaders → divider → Footer. */}
  {detailed && <div class="services-divider" aria-hidden="true"></div>}
</section>

{/* Detail panel — only the detailed /sluzby variant renders it (so its
    CSS + JS never ship on the homepage). */}
{detailed && <ServiceDetail lang={lang} />}

<style>
  /* ===== Section frame =====
     Same vertical scale (clamp 60→180) and page-edge gutters as
     About/Works so all three "documents" align to the same outer
     ruler. Background var(--bg) cream — no dark-section break
     (that idea was scrapped after V3 comparison). */
  .services {
    display: flex;
    flex-direction: column;
    /* 40 at 1440 → 60 at 2160+ */
    gap: clamp(28px, 2.78vw, 60px);
    width: 100%;
    /* max-width + margin auto mirror the .works wrapper exactly so
       both sections cap and centre at the same outer width; without
       this Services kept growing past the Works canvas at large
       viewports. */
    max-width: 2464px;
    margin: 0 auto;
    /* 80 at 1440 (Figma py-80) — caps at 80 above 1440 so vertical
       rhythm stays consistent with Works/Leaders/Footer.
       28 at 1440 → 48 at 2400+ horizontal. */
    padding: clamp(48px, 5.55vw, 80px) clamp(16px, 2vw, 48px);
    background: var(--bg);
  }

  /* Detailed variant drops the bottom padding so its closing divider sits
     flush at the section edge, then the footer follows — same rhythm as
     the homepage Leaders → divider → Footer. */
  .services--detailed {
    padding-bottom: 0;
  }

  .services-divider {
    width: 100%;
    height: 1px;
    background: var(--line);
    margin: clamp(40px, 5.55vw, 120px) 0 0;
  }

  /* ===== Top label "Služby" =====
     Capped at 20px (Figma baseline) — Services intentionally
     doesn't scale above 1440 like Works/Leaders, so every text
     element here stays at the spec 20px even on large viewports.
     Weight Regular 400 — every text element in this section
     reads at the same Regular weight (unlike Works/Leaders
     where labels/titles are Medium). */
  .services-label {
    width: 100%;
    font-family: var(--font-sans);
    font-weight: 400;
    font-style: normal;
    font-size: clamp(16px, 1.39vw, 20px);
    line-height: normal;
    letter-spacing: 0.02em;
    color: var(--ink);
  }

  /* ===== Rows list =====
     No max-width — the list inherits the section's max-width
     (2464) so rows grow with viewport just like the .works grid.
     Earlier 1384 cap on the list was creating extra visual gutter
     against the section's padding at wider viewports. */
  .services-list {
    list-style: none;
    margin: 0;
    padding: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
  }

  /* Hairline divider between rows. First row has no top padding
     (it sits flush under the label gap); last row has no bottom
     border (closes the table cleanly so the CTA isn't separated
     by a free-floating hairline). */
  .service-row {
    padding: clamp(20px, 1.94vw, 36px) 0;
    border-bottom: 1px solid var(--line);
  }

  .service-row:first-child {
    padding-top: 0;
  }

  /* Last row drops BOTH border-bottom (closes the table) AND
     padding-bottom (zero). Without this the 28px row padding
     stacked with the 48px CTA margin produced ~76px of optical
     space below the last item — too much air. The CTA's own
     margin-top owns the gap entirely. */
  .service-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  /* The 3-column row layout. justify-content: space-between
     distributes whatever space is left after the three fixed
     columns claim their share — keeps the visual alignment
     between the desc column and the media column exact. */
  .service-row-inner {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: clamp(32px, 4vw, 80px);
    width: 100%;
  }

  /* ===== Meta column — number + title ===== */
  .service-meta {
    flex: 0 0 calc(327 / 1384 * 100%);
    display: flex;
    align-items: baseline;
    gap: clamp(28px, 4.17vw, 60px);
    min-width: 0;
  }

  /* All text in the Services row is capped at 20px AND Regular
     weight 400 (Figma spec). Number, title and description share
     the same clamp + weight so the row reads as a single
     typographic line — no Medium "headings" inside the row. */
  .service-num {
    flex: 0 0 auto;
    font-family: var(--font-sans);
    font-weight: 400;
    font-style: normal;
    font-size: clamp(16px, 1.39vw, 20px);
    line-height: 1.2;
    letter-spacing: 0.02em;
    color: var(--ink);
    font-variant-numeric: tabular-nums;
    /* Reveal is the same clip-path curtain as the photo —
       services.ts animates inset(100% 0 0 0) → inset(0). */
    will-change: clip-path;
    display: inline-block;
  }

  .service-title {
    font-family: var(--font-sans);
    font-weight: 400;
    font-style: normal;
    font-size: clamp(16px, 1.39vw, 20px);
    line-height: 1.2;
    letter-spacing: 0.02em;
    color: var(--ink);
    margin: 0;
    will-change: clip-path;
  }

  /* ===== Description column =====
     A flex-col container so the detailed /sluzby variant can stack the
     "Obsahuje" list + "Dozvedieť sa viac" link under the desc. The
     clip-path reveal (services.ts) targets THIS container, so the whole
     column unrolls as one. */
  .service-desc {
    flex: 0 0 calc(445 / 1384 * 100%);
    display: flex;
    flex-direction: column;
    gap: clamp(20px, 2.22vw, 32px);
    min-width: 0;
    margin: 0;
    will-change: clip-path;
  }

  /* Desc text — capped at 20px, line-height 1.4 (= 28/20). */
  .service-desc-text {
    font-family: var(--font-sans);
    font-weight: 400;
    font-style: normal;
    font-size: clamp(16px, 1.39vw, 20px);
    line-height: 1.4;
    letter-spacing: 0.02em;
    color: var(--ink);
    margin: 0;
  }

  /* ===== Detailed variant — "Obsahuje" list + per-row link ===== */
  .service-includes {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .service-includes-label {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(16px, 1.39vw, 20px);
    line-height: 1.4;
    letter-spacing: 0.02em;
    color: var(--text-mute);
    margin: 0;
  }

  /* Bulleted contents — overrides the global `ul { list-style: none }`. */
  .service-includes-list {
    list-style: disc;
    margin: 0;
    padding-left: 30px;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(16px, 1.39vw, 20px);
    line-height: 1.5;
    letter-spacing: 0.02em;
    color: var(--ink);
  }

  .service-includes-list li {
    margin: 0;
  }

  /* "Dozvedieť sa viac →" — underlined text link (not the filled CTA);
     align-self keeps the underline only as wide as the text. The
     underline is a ::after so it can wipe on hover. */
  .service-more {
    position: relative;
    display: inline-flex;
    align-self: flex-start;
    align-items: center;
    gap: clamp(8px, 0.83vw, 12px);
    padding-bottom: 4px;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(14px, 1.11vw, 16px);
    letter-spacing: 0.02em;
    color: var(--ink);
    text-decoration: none;
  }

  .service-more::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background: var(--ink);
    transform-origin: left;
  }

  /* Hover — the underline wipes through left-to-right (retracts to the
     right, redraws from the left); the arrow leans into the click. */
  .service-more:hover::after {
    animation: serviceMoreWipe 560ms cubic-bezier(0.65, 0, 0.35, 1);
  }

  @keyframes serviceMoreWipe {
    0% { transform: scaleX(1); transform-origin: right; }
    45% { transform: scaleX(0); transform-origin: right; }
    55% { transform: scaleX(0); transform-origin: left; }
    100% { transform: scaleX(1); transform-origin: left; }
  }

  .service-more-arrow {
    display: block;
    flex: 0 0 auto;
    transition: transform 360ms cubic-bezier(0.65, 0, 0.35, 1);
  }

  .service-more:hover .service-more-arrow {
    transform: translateX(4px);
  }


  /* ===== Media frame =====
     Two aspect ratios drive the asymmetric rhythm of the section:
       - Portrait (rows 01, 04): 328 / 400 ≈ 0.82 (taller than wide)
       - Landscape (rows 02, 03, 05): 328 / 193 ≈ 1.70 (wide strip)
     overflow:hidden clips the parallax-overflow image (122% tall)
     and any future hover-scale. */
  /* clip-path initial = fully clipped from top. services.ts
     animates each row's media to inset(0) when the row enters
     viewport, so every photo "unrolls" from below in sync with
     its text reveal. */
  .service-media {
    position: relative;
    flex: 0 0 calc(328 / 1384 * 100%);
    overflow: hidden;
    background: var(--surface);
    clip-path: inset(100% 0 0 0);
    will-change: clip-path;
  }

  .service-media--portrait {
    aspect-ratio: 328 / 400;
  }

  .service-media--landscape {
    aspect-ratio: 328 / 193;
  }

  /* Image overflow trick for the parallax — identical maths to
     Works: image is 122% of frame height with top:-11%, giving
     11% headroom on each side for the ±8 yPercent scrub to drift
     inside without ever revealing the frame's edge. will-change
     promotes the layer to the GPU so the scrub stays buttery. */
  .service-media img {
    position: relative;
    top: -11%;
    width: 100%;
    height: 122%;
    object-fit: cover;
    display: block;
    will-change: transform;
  }

  /* ===== Initial reveal state (CSS-owned, pre-paint) =====
     Pre-paint state is fully clipped from the top (matches the
     photo's .service-media initial state). services.ts animates
     each element's clip-path to inset(0) when the row enters
     viewport — the text and photo "unroll" from below with the
     same curtain motion, so the whole row reads as one family. */
  .service-num[data-reveal],
  .service-title[data-reveal],
  .service-desc[data-reveal] {
    clip-path: inset(100% 0 0 0);
  }


  /* ===== CTA — mirrors About / Works / Hero CTA pattern =====
     Dark curtain slides in from the left on hover; text shifts a
     touch, arrow runs ahead. align-self:center is what positions
     it as the centred "closing chord" beneath the rows. */
  .services-cta {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(10px, 0.83vw, 12px);
    /* Figma spec 211×44 px — clamps cap at those values so the
       button never grows past spec above 1440. */
    width: clamp(180px, 14.65vw, 211px);
    /* 48 at 1440 Figma baseline → caps at 48 above so the gap
       below the last row stays the spec value. */
    margin-top: clamp(24px, 3.33vw, 48px);
    padding: clamp(10px, 0.97vw, 14px) clamp(12px, 1.11vw, 16px);
    background: var(--btn-bg);
    color: var(--btn-fg);
    text-decoration: none;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(14px, 1.11vw, 16px);
    line-height: 1;
    letter-spacing: 0.02em;
    overflow: hidden;
    align-self: center;
    will-change: transform;
  }

  .services-cta::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--btn-bg-hover);
    transform: translateX(-101%);
    transition: transform 520ms cubic-bezier(0.65, 0, 0.35, 1);
    will-change: transform;
    z-index: 0;
  }

  .services-cta:hover::before {
    transform: translateX(0);
  }

  .services-cta > * {
    position: relative;
    z-index: 1;
  }

  .services-cta-text {
    display: inline-block;
    transition: transform 420ms cubic-bezier(0.65, 0, 0.35, 1);
    will-change: transform;
  }

  .services-cta:hover .services-cta-text {
    transform: translateX(3px);
  }

  .services-cta-arrow {
    display: block;
    flex: 0 0 auto;
    transition: transform 440ms cubic-bezier(0.65, 0, 0.35, 1);
    will-change: transform;
  }

  .services-cta:hover .services-cta-arrow {
    transform: translateX(7px);
  }

  /* =============================================================
     Responsive
     -----------------------------------------------------------------
     TABLET (768–1199): no rule — the 3-column row + clamp() values
     scale down proportionally (scaled-down desktop).

     MOBILE (≤767): the Figma mobile layout — the number sits in a
     narrow left column with the title + description stacked beside
     it, and the photo runs full-width below. `display: contents` on
     .service-meta promotes its number + title into the row grid so
     each can take a distinct cell.
     ============================================================= */
  @media (max-width: 767px) {
    .services {
      gap: 24px;
      padding: 56px 16px;
    }
    .service-row {
      padding: 28px 0;
    }

    .service-row-inner {
      display: grid;
      grid-template-columns: 56px 1fr;
      grid-template-areas:
        "num   title"
        "num   desc"
        "media media";
      column-gap: 20px;
      row-gap: 32px;
      align-items: start;
    }
    .service-meta {
      display: contents;
    }
    .service-num {
      grid-area: num;
    }
    .service-title {
      grid-area: title;
    }
    .service-desc {
      grid-area: desc;
      flex: none;
      width: 100%;
    }
    .service-media {
      grid-area: media;
      flex: none;
      width: 100%;
      margin-top: 8px;
    }

    /* Figma mobile spec sheet — uniform Switzer Regular, ~18px so the
       long descriptions stay comfortable on a narrow column. */
    .service-num,
    .service-title,
    .service-desc-text,
    .service-includes-label,
    .service-includes-list {
      font-size: 18px;
    }
    .service-desc-text {
      line-height: 1.5;
    }
  }
</style>
