---
/**
 * Služby — intro ("drawing becomes reality").
 *
 * The technical BLUEPRINT shows first and, on load, rises + zooms to the
 * full-bleed hero; the finished PHOTO then veils in top→bottom on scroll
 * (see scripts/services-intro.ts). The title band below reveals word by
 * word as you scroll — the same colour scrub as the home About section.
 *
 * Nav is the shared <Nav> component (variant "sub") — one source of
 * truth across the whole site. Its theme-switch observes `.sintro`
 * (the boundary default for the sub variant).
 */
const titleText =
  "Za každou čiarou vo výkrese vidíme ľudské príbehy. Nestaviame na pominuteľných trendoch, ale na svetle, materiáloch a vašich rituáloch. Vytvárame priestor, ktorý s vami prirodzene splynie.";
const titleWords = titleText.split(" ");
---

<section class="sintro" aria-label="Služby">
  <div class="sintro-stage">
    {/* The picture: blueprint (bottom) + finished photo (top). Both
        ride the frame's intro transform together, so they stay aligned
        while it rises and zooms to full-bleed. */}
    <div class="sintro-frame">
      {/* Blueprint — shown first; the drawing the project starts from. */}
      <img
        class="sintro-layer sintro-blueprint"
        src="/images/services-intro/intro-blueprint.png"
        alt=""
        aria-hidden="true"
        decoding="async"
      />
      {/* Finished photo — veils in over the blueprint on scroll; also
          the reduced-motion fallback (shown straight away). */}
      <img
        class="sintro-layer sintro-photo"
        src="/images/services-intro/intro-photo.jpg"
        alt="Dokončený rodinný dom za súmraku — výsledok projektu ateliéru."
        decoding="async"
      />
    </div>
    {/* Top scrim — keeps the light nav legible over both layers. */}
    <div class="sintro-scrim" aria-hidden="true"></div>
  </div>
</section>

{/* Title band — leads from the photo into the services documentation. */}
<section class="sintro-title">
  <p class="sintro-title-text">
    {
      titleWords.map((word, i) => (
        <>
          <span class="sintro-word">{word}</span>
          {i < titleWords.length - 1 ? " " : ""}
        </>
      ))
    }
  </p>
</section>

<style>
  /* ===== Reveal stage ===== */
  /* Extra height gives the scroll distance for the veil while the stage
     stays pinned (sticky). */
  .sintro {
    position: relative;
    height: 220vh;
  }

  .sintro-stage {
    position: sticky;
    top: 0;
    width: 100%;
    height: 100vh;
    min-height: 600px;
    overflow: hidden;
    /* Cream surround behind the 80% intro frame (matches the page). */
    background: var(--bg);
  }

  /* Frame holds BOTH layers and carries the whole intro motion. GSAP
     owns the transform (see services-intro.ts) — do NOT set a CSS
     transform here; opacity:0 only, to avoid a pre-JS flash. */
  .sintro-frame {
    position: absolute;
    inset: 0;
    z-index: 1;
    transform-origin: center center;
    opacity: 0;
    overflow: hidden;
    will-change: transform, opacity;
  }

  .sintro-layer {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Blueprint — shown first, sits beneath the photo. */
  .sintro-blueprint {
    object-fit: cover;
    z-index: 1;
  }

  /* Finished photo — veils in over the blueprint top → bottom on
     scroll (clip-path bottom inset 100% → 0%). */
  .sintro-photo {
    object-fit: cover;
    z-index: 2;
    clip-path: inset(0 0 100% 0);
  }

  /* Top scrim — keeps the light nav legible over both the white
     blueprint and the photo. */
  .sintro-scrim {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 220px;
    z-index: 4;
    pointer-events: none;
    background: linear-gradient(rgba(0, 0, 0, 0.42), rgba(0, 0, 0, 0));
  }

  /* ===== Title band ===== */
  .sintro-title {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(56px, 6.94vw, 100px) clamp(16px, 2vw, 48px);
    background: var(--bg);
  }
  .sintro-title-text {
    font-family: var(--font-sans);
    font-weight: 500;
    font-style: normal;
    font-size: clamp(28px, 3.33vw, 48px);
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--ink);
    text-align: center;
    max-width: 1150px;
    margin: 0;
  }

  /* Per-word span — colour is a token color-mix driven by --reveal
     (0 → 1, scrubbed in services-intro.ts), so it reveals correctly in
     both themes. Same pattern as the home About headline. */
  .sintro-word {
    color: color-mix(in srgb, var(--ink) calc(var(--reveal, 0) * 100%), var(--ink-faint));
    will-change: color;
  }
</style>

<script>
  import { initServicesIntro } from "../scripts/services-intro";
  initServicesIntro();
</script>
